rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write their own documents and subcollections
    match /users/{userId} {
      allow read, write, create, update, delete: if request.auth.uid == userId;
      
      // Allow access to all subcollections (e.g., calendars, selfcare)
      match /{document=**} {
        allow read, write, create, update, delete: if request.auth.uid == userId;
      }
    }

    // Allow any authenticated user to read public data
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
